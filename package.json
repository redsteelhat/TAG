{
  "name": "tag-driver-finance-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=22.12.0 <25"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "db:backup": "node scripts/backup/postgres-backup.mjs",
    "db:backup:watch": "node scripts/backup/postgres-backup.mjs --watch",
    "db:generate": "pnpm --filter @tag/api db:generate",
    "db:migrate": "pnpm --filter @tag/api db:migrate",
    "db:seed": "pnpm --filter @tag/api db:seed",
    "db:studio": "pnpm --filter @tag/api db:studio",
    "db:validate": "pnpm --filter @tag/api db:validate",
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:api": "pnpm --filter @tag/api dev",
    "dev:mobile": "pnpm --filter @tag/mobile dev",
    "dev:web": "pnpm --filter @tag/web dev",
    "api:load": "node scripts/performance/api-load-test.mjs",
    "api:perf": "node scripts/performance/api-performance-test.mjs",
    "lint": "pnpm -r --if-present lint",
    "postinstall": "pnpm db:generate",
    "test:reports": "node scripts/quality/report-validation.mjs",
    "test:responsive": "node scripts/quality/responsive-test.mjs",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "prettier": "^3.5.3",
    "typescript": "^6.0.3"
  }
}
