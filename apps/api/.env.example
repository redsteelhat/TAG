DATABASE_URL=postgresql://tag_user:tag_password@localhost:5432/tag_finance?schema=public
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8083
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE_SECONDS=600
BODY_LIMIT=2mb
SWAGGER_ENABLED=true
TRUST_PROXY=
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE_SECONDS=15552000
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120
ERROR_TRACKING_ENABLED=false
ERROR_TRACKING_WEBHOOK_URL=
ERROR_TRACKING_AUTH_TOKEN=
ERROR_TRACKING_ENVIRONMENT=development
ERROR_TRACKING_RELEASE=local
ERROR_TRACKING_SAMPLE_RATE=1
ERROR_TRACKING_TIMEOUT_MS=3000
MONITORING_TOKEN=change-me-monitoring-token
PERF_API_BASE_URL=http://localhost:3001/api/v1
PERF_CONCURRENCY=10
PERF_DURATION_SECONDS=15
PERF_P95_THRESHOLD_MS=500
PERF_ERROR_RATE_THRESHOLD=0.01
PERF_REQUEST_TIMEOUT_MS=5000
PERF_WARMUP_REQUESTS=5
LOAD_API_BASE_URL=http://localhost:3001/api/v1
LOAD_STAGES=10:10,25:20,50:30,10:10
LOAD_P95_THRESHOLD_MS=750
LOAD_ERROR_RATE_THRESHOLD=0.02
LOAD_REQUEST_TIMEOUT_MS=5000
LOAD_WARMUP_REQUESTS=10
QUEUE_CONCURRENCY=2
QUEUE_MAX_ATTEMPTS=3
BACKUP_DIR=backups/postgres
BACKUP_FILE_PREFIX=tag-finance
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_HOURS=24
# Local Docker fallback. Leave empty to use pg_dump from PATH.
BACKUP_DOCKER_CONTAINER=tag-postgres
# Optional host binary override, for example C:\Program Files\PostgreSQL\16\bin\pg_dump.exe
BACKUP_PG_DUMP_BIN=pg_dump
BACKUP_PG_SCHEMA=public
REMINDER_JOBS_ENABLED=true
REMINDER_JOBS_INTERVAL_MS=21600000
PACKAGE_ENDING_REMINDER_DAYS=3
RECURRING_DUE_REMINDER_DAYS=7
MAINTENANCE_REMINDER_THRESHOLD_KM=500
